---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.jsx';
import MagazinePage from '../components/MagazinePage.jsx';

const { pathname } = Astro.url;
---

<Layout 
	title="2025 Design Portfolio" 
	description="Experience the SIRO 'STRIPES' portfolio. A high-fidelity digital lookbook showcasing our latest editorial uniform collections."
>
	<Navbar client:load pathname={pathname} />
	<main>
		<MagazinePage client:idle />
	</main>
</Layout>

<style>
	main {
		width: 100%;
		overflow-x: hidden;
	}
</style>
