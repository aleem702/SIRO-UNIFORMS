---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.jsx';
import LandingPage from '../components/LandingPage.jsx';

const { pathname } = Astro.url;
---

<Layout 
	title="Premium Uniform Manufacturing" 
	description="SIRO Uniforms delivers professional corporate couture, specialized healthcare scrubs, and bespoke hospitality attire. Kerala's leading uniform label serving the GCC and India."
>
	<Navbar client:load pathname={pathname} />
	<main>
		<LandingPage client:idle />
	</main>
</Layout>

<style>
	main {
		width: 100%;
	}
</style>
