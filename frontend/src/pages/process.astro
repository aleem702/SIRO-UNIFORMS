---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar';
import Footer from '../components/Footer';
import ProcessPage from '../components/ProcessPage';

const pathname = new URL(Astro.request.url).pathname;
---

<Layout 
	title="Our Service Roadmap" 
	description="Discover the SIRO Method: A precision-driven architectural roadmap to outfitting your organization from first consultation to bulk deployment."
>
	<Navbar client:load pathname={pathname} />
	<main>
		<ProcessPage client:idle />
	</main>
</Layout>
