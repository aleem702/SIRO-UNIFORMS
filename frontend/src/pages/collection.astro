---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.jsx';
import CollectionsPage from '../components/CollectionsPage.jsx';

const { pathname } = Astro.url;
---

<Layout 
	title="Digital Exhibit Gallery" 
	description="Browse the SIRO Studio high-fidelity uniform collection. Featuring interactive 360 viewer experiences for Corporate, Healthcare, and Hospitality sectors."
>
	<Navbar client:load pathname={pathname} />
	<main>
		<CollectionsPage client:idle />
	</main>
</Layout>

<style>
	main {
		width: 100%;
		overflow-x: hidden;
		background: var(--background);
	}
</style>
