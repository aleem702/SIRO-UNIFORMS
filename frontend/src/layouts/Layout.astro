---
import '../styles/global.css';

interface Props {
	title: string;
}

const { title } = Astro.props;
const { pathname } = Astro.url;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content="SIRO Uniforms - Professional Uniform Solutions" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
	</head>
	<body>
		<slot />
		<script>
			import Lenis from 'lenis';

			// Initialize Lenis
			const lenis = new Lenis({
				duration: 1.2,
				easing: (t) => Math.min(1, 1.001 - Math.pow(2, -10 * t)),
				direction: 'vertical',
				gestureDirection: 'vertical',
				smoothWheel: true,
				wheelMultiplier: 1,
				smoothTouch: false,
				touchMultiplier: 2,
				infinite: false,
			});

			function raf(time) {
				lenis.raf(time);
				requestAnimationFrame(raf);
			}

			requestAnimationFrame(raf);

			// Optional: make lenis accessible worldwide if needed
			// window.lenis = lenis;
		</script>
	</body>
</html>
