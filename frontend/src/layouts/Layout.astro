---
import '../styles/global.css';

interface Props {
	title: string;
	description?: string;
}

const { title, description = "SIRO Uniforms - Professional Uniform Solutions. Premium uniform manufacturing based in Kerala, India, serving Education, Healthcare, and Corporate sectors." } = Astro.props;
const { pathname } = Astro.url;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content={description} />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="icon" type="image/png" href="/favicon.png" />
		<meta name="generator" content={Astro.generator} />
		<title>{title} | SIRO Uniforms</title>
	</head>
	<body>
		<noscript>
			<div style="padding: 20px; text-align: center; background: var(--accent); color: white;">
				This site requires JavaScript for the full immersive experience. Please enable it in your browser.
			</div>
		</noscript>
		<slot />
		<script>
			import Lenis from 'lenis';

			// Initialize Lenis
			const lenis = new Lenis({
				duration: 1.2,
				easing: (t) => Math.min(1, 1.001 - Math.pow(2, -10 * t)),
				direction: 'vertical',
				gestureDirection: 'vertical',
				smoothWheel: true,
				wheelMultiplier: 1,
				smoothTouch: false,
				touchMultiplier: 2,
				infinite: false,
			});

			function raf(time) {
				lenis.raf(time);
				requestAnimationFrame(raf);
			}

			requestAnimationFrame(raf);

			// Optional: make lenis accessible worldwide if needed
			// window.lenis = lenis;
		</script>
	</body>
</html>
